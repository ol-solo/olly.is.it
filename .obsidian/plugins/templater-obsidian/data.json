{
  "command_timeout": 5,
  "templates_folder": "templates",
  "templates_pairs": [
    [
      "",
      ""
    ]
  ],
  "trigger_on_file_creation": true,
  "auto_jump_to_cursor": true,
  "enable_system_commands": false,
  "shell_path": "",
  "user_scripts_folder": "script",
  "enable_folder_templates": true,
  "folder_templates": [
    {
      "folder": "/",
      "template": "templates/inbox_template.md"
    },
    {
      "folder": "projects/movies",
      "template": "templates/movie_template.md"
    },
    {
      "folder": "projects/books",
      "template": "templates/book_template.md"
    },
    {
      "folder": "projects/courses",
      "template": "templates/course_template.md"
    },
    {
      "folder": "projects/articles",
      "template": "templates/article_teamplate.md"
    }
  ],
  "enable_file_templates": false,
  "file_templates": [
    {
      "regex": ".*",
      "template": ""
    }
  ],
  "syntax_highlighting": true,
  "syntax_highlighting_mobile": false,
  "enabled_templates_hotkeys": [
    "templates/inbox_template.md",
    "templates/code.md",
    "templates/math.md",
    "templates/note_template.md",
    "templates/course_note.md",
    "templates/update_nav_button.md",
    "templates/embed_current_block.md"
  ],
  "startup_templates": [
    ""
  ],
  "intellisense_render": 1
}